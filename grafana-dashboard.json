{
  "title": "llama.cpp",
  "uid": "llamacpp-metrics",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "tags": ["llama.cpp", "llm"],
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(llamacpp:requests_processing, model)",
        "label": "Model",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Requests",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 4 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "sum(llamacpp:requests_processing{model=~\"$model\"})",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Deferred Requests",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "sum(llamacpp:requests_deferred{model=~\"$model\"})",
          "legendFormat": "deferred"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Prompt Throughput",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "displayName": "${__field.labels.model}"
        }
      },
      "targets": [
        {
          "expr": "llamacpp:prompt_tokens_seconds{model=~\"$model\"}",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Generation Throughput",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "displayName": "${__field.labels.model}"
        }
      },
      "targets": [
        {
          "expr": "llamacpp:predicted_tokens_seconds{model=~\"$model\"}",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Prompt Throughput (tokens/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "llamacpp:prompt_tokens_seconds{model=~\"$model\"}",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Generation Throughput (tokens/s)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "llamacpp:predicted_tokens_seconds{model=~\"$model\"}",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Prompt Token Rate",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(llamacpp:prompt_tokens_total{model=~\"$model\"}[5m])",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Generation Token Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "/ s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(llamacpp:tokens_predicted_total{model=~\"$model\"}[5m])",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Active / Deferred Requests",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "llamacpp:requests_processing{model=~\"$model\"}",
          "legendFormat": "processing — {{model}}"
        },
        {
          "expr": "llamacpp:requests_deferred{model=~\"$model\"}",
          "legendFormat": "deferred — {{model}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Busy Slots per Decode",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "llamacpp:n_busy_slots_per_decode{model=~\"$model\"}",
          "legendFormat": "{{model}}"
        }
      ]
    }
  ]
}
